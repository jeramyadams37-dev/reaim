rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /attachments/{chatId}/{fileName} {
      allow read, write: if request.auth != null &&
        (chatId.matches('^' + request.auth.token.email.split('@')[0] + '_.*') ||
         chatId.matches('.*_' + request.auth.token.email.split('@')[0] + '$'));
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
